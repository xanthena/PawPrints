GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Highlight timeline routing. Explicit function/CLI arguments override these.
# If these are omitted, the highlight module follows VISION_MODEL_PRIMARY and
# VISION_MODEL_FALLBACK, then defaults to Gemini with Qwen as fallback.
# Supported identifiers: gemini, qwen, claude, openai.
HIGHLIGHT_MODEL_PRIMARY=gemini
HIGHLIGHT_MODEL_FALLBACK=qwen
VISION_MODEL_PRIMARY=gemini
VISION_MODEL_FALLBACK=qwen
