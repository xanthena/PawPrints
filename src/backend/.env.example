GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# which vision model to try first: "gemini", "qwen" (local, via Ollama),
# "claude", or "openai". Gemini and qwen are the two paths actually
# tested end-to-end; claude/openai are wired up the same way but not
# yet verified against a real key. If gemini is preferred and hits a
# rate limit or is unavailable, it falls back to qwen automatically for
# that call -- claude/openai have no such fallback.
VISION_MODEL_PREFERENCE=qwen

# model names -- change these without touching any code
OLLAMA_MODEL=qwen2.5vl:3b
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# how google_gemini.py authenticates:
# "api_key" (default) - Gemini Developer API / AI Studio, needs only
#   GEMINI_API_KEY above. This is the path judges/teammates should use.
# "vertex" - Vertex AI + Application Default Credentials (run
#   `gcloud auth application-default login` first), needs GOOGLE_PROJECT_ID
#   below instead. Useful for testing against a GCP account's free
#   credits when the AI Studio free tier itself won't allow calls.
GEMINI_AUTH_MODE=api_key
GOOGLE_PROJECT_ID=
