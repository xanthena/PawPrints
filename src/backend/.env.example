GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# which vision model to try first, and which one to fall back to if
# that call raises anything at all (rate limit, missing key, missing
# package, or any other failure). Each is one of "gemini", "qwen"
# (local, via Ollama), "claude", or "openai". Gemini and qwen are the
# two paths actually tested end-to-end; claude/openai are wired up the
# same way but not yet verified against a real key. Set fallback equal
# to primary (or blank) to disable fallback entirely.
VISION_MODEL_PRIMARY=gemini
VISION_MODEL_FALLBACK=qwen

# model names -- change these without touching any code
OLLAMA_MODEL=qwen2.5vl:3b
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# how google_gemini.py authenticates:
# "api_key" (default) - Gemini Developer API / AI Studio, needs only
#   GEMINI_API_KEY above. This is the path judges/teammates should use.
# "vertex" - Vertex AI + Application Default Credentials (run
#   `gcloud auth application-default login` first), needs GOOGLE_PROJECT_ID
#   below instead. Useful for testing against a GCP account's free
#   credits when the AI Studio free tier itself won't allow calls.
GEMINI_AUTH_MODE=api_key
GOOGLE_PROJECT_ID=

# Highlight timeline routing. Explicit function/CLI arguments override these.
# If these are omitted, the highlight module follows VISION_MODEL_PRIMARY and
# VISION_MODEL_FALLBACK, then defaults to Gemini with Qwen as fallback.
# Supported identifiers: gemini, qwen, claude, openai.
HIGHLIGHT_MODEL_PRIMARY=gemini
HIGHLIGHT_MODEL_FALLBACK=qwen

